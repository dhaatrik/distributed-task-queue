# ============================================================
# TaskForge — Environment Variable Template
# Copy this file to `.env` and fill in all values before
# running the application in any non-development environment.
# ============================================================

# ----------------------------------------------------------
# FastAPI / Application
# ----------------------------------------------------------

# REQUIRED in production: Generate with `openssl rand -hex 32`
# If unset, a random key is auto-generated at startup (NOT safe for production
# because all JWT tokens are invalidated on every restart).
APP_SECRET_KEY=

# Path (relative or absolute) to the SQLite database file.
# Default: tasks_and_users.db (created in the working directory)
DATABASE_URL=tasks_and_users.db

# ----------------------------------------------------------
# Celery / Redis
# ----------------------------------------------------------

# Full Redis URL used by Celery as the message broker.
# For password-protected Redis: redis://:yourpassword@host:6379/0
# Default: redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0

# Full Redis URL used by Celery to store task results.
# Can be the same as CELERY_BROKER_URL or a separate DB index.
# Default: redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
