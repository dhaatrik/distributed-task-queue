# =============================================================
# TaskForge — .gitignore
# =============================================================

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# ── Virtual environments ──────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Distribution / packaging ──────────────────────────────────
dist/
build/
*.egg-info/
*.egg
.eggs/

# ── Project-specific ─────────────────────────────────────────
.env
*.db
*.db-shm
*.db-wal

# ── Celery ───────────────────────────────────────────────────
celerybeat-schedule
celerybeat.pid

# ── Testing & coverage ───────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── Type checkers ────────────────────────────────────────────
.mypy_cache/
.pytype/
.ruff_cache/

# ── IDE / editors ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
